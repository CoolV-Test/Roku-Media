{% assign newline = "
" %}
{
  "providerName": "{{ site.name }}",
  "language": "{{ site.lang }}",
  "lastUpdated": "{{ site.time | date_to_rfc822 }}",
{% for collection in site.collections %}
  {% unless collection.mediaContent %}
    {% continue %}
  {% endunless %}
  "{{ collection.label }}": [
  {% for post in site[collection.label] %}
    {
      "id": "{{ post.id }}",
      "title": "{{ post.title }}",
      "shortDescription": "{{ post.description }}",
      "thumbnail": "{{ post.thumbnail }}",
      "genres": [
      {% for category in post.category %}
        "{{ category }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
      ],
      "tags": [
      {% for tag in post.tags %}
        "{{ tag }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
      ],
      "releaseDate": "{{ post.releaseDate }}",
      "content": {
        "dateAdded": "{{ post.date | date_to_xmlschema }}",
        "captions": [
        {% for caption in post.captions %}
          "{{ caption }}"{% unless forloop.last %},{% endunless %}
        {% endfor %}
        ],
        "duration": {{ post.duration }},
        "adBreaks": [
        {% for adBreak in post.adBreaks %}
          "{{ adBreak }}"{% unless forloop.last %},{% endunless %}
        {% endfor %}
        ],
        "videos": [
        {% for video in post.videos %}
          {
            "url": "{{ video.url }}",
            "quality": "{{ video.quality }}",
            "videoType": "{{ video.videoType }}"
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
        ]
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
{% endfor %}
  "playlists": [
  {% for post in site.posts %}
    {% assign itemIds = post.content | split: newLine %}
    {
      "name": "{{ post.title }}",
      "itemIds": [
      {% for itemId in itemIds %}
        "{{ itemId }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
      ]
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ],
  "categories": [
  {% for category in site.categories %}
    {
      "name": "{{ category[0] }}",
      "playlistName": "{{ category[0] }}",
      "order": "manual"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ]
}
