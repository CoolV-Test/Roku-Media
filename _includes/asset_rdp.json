{% assign asset = include.asset %}
{
  "id": "{{ asset.id }}",
  "title": "{{ asset.title }}",
  "shortDescription": "{{ asset.shortDescription }}",
  "thumbnail": "{{ asset.thumbnail }}",
  "genres": [
  {% for genre in asset.genres %}
    "{{ genre }}"{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ],
  "tags": [
  {% for tag in asset.tags %}
    "{{ tag }}"{% unless forloop.last %},{% endunless %}
  {% endfor %}
  ],
  "releaseDate": "{{ asset.id }}",
  "content": {
    "dateAdded": "{{ asset.content.dateAdded }}",
    "captions": [
    {% for caption in asset.content.captions %}
      "{{ caption }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
    ],
    "duration": {{ asset.content.duration }},
    "adBreaks": [
    {% for adBreak in asset.content.adBreaks %}
      "{{ adBreak }}"{% unless forloop.last %},{% endunless %}
    {% endfor %}
    ],
    "videos": [
    {% for video in asset.content.videos %}
      {
        "url": "{{ video.url }}",
        "quality": "{{ video.quality }}",
        "videoType": "{{ video.videoType }}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    ]
  }
}
